# Copie para .env.local (gitignored) e preencha com os valores reais.
# Painel Supabase: Project Settings > API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dominio final do site (usado em sitemap.xml, robots.txt e og:image).
NEXT_PUBLIC_SITE_URL=https://catech.ind.br

# Envio de email transacional (Resend). Painel: https://resend.com
# - RESEND_API_KEY: em API Keys (comeca com "re_").
# - EMAIL_FROM: endereco de um dominio VERIFICADO no Resend (catech.ind.br).
RESEND_API_KEY=
EMAIL_FROM=Catech 360 <no-reply@catech.ind.br>
